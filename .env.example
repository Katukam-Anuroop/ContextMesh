# ContextSync Environment Variables
# Copy this file to .env and fill in your API key

# LLM Provider API Key (pick one based on your .contextsync.yaml provider setting)
GEMINI_API_KEY=your-gemini-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here

# For local Ollama, no key needed — just run: ollama serve
